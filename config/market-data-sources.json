{
  "marketDataProvider": {
    "name": "Public market data endpoints",
    "url": "https://query1.finance.yahoo.com/v8/finance/chart/{symbol}",
    "note": "指数・為替・商品はYahoo Finance chart JSON、米10年金利はFRED公開CSVを取得する。取得失敗時は公開停止し、値の再配信は最小限に留める。"
  },
  "range": "10d",
  "interval": "1d",
  "requestTimeoutMs": 15000,
  "maxDataAgeDays": 5,
  "instruments": [
    {
      "key": "nikkei",
      "label": "日経平均",
      "symbol": "^N225",
      "market": "Japan",
      "format": "index",
      "required": true
    },
    {
      "key": "topix",
      "label": "TOPIX連動ETF(1306)",
      "symbol": "1306.T",
      "market": "Japan",
      "format": "index",
      "required": true,
      "proxyFor": "TOPIX",
      "note": "TOPIX本指数の直取得が安定しないため、当面はTOPIX連動ETFを参考値として表示する。",
      "referenceLinks": [
        {
          "label": "世界の株価 TOPIX",
          "url": "https://nikkei225jp.com/_ssi/if/?c=112"
        },
        {
          "label": "世界の株価",
          "url": "https://nikkei225jp.com/"
        }
      ]
    },
    {
      "key": "sp500",
      "label": "S&P 500",
      "symbol": "^GSPC",
      "market": "United States",
      "format": "index",
      "required": true
    },
    {
      "key": "nasdaq",
      "label": "NASDAQ",
      "symbol": "^IXIC",
      "market": "United States",
      "format": "index",
      "required": true
    },
    {
      "key": "usdjpy",
      "label": "ドル円",
      "symbol": "USDJPY=X",
      "market": "FX",
      "format": "fx",
      "required": true
    },
    {
      "key": "us10y",
      "label": "米10年金利",
      "provider": "fred",
      "symbol": "DGS10",
      "seriesId": "DGS10",
      "market": "Rates",
      "format": "yield",
      "required": true,
      "sourceUrl": "https://fred.stlouisfed.org/series/DGS10",
      "note": "FREDのMarket Yield on U.S. Treasury Securities at 10-Year Constant Maturityの参考値。"
    },
    {
      "key": "wti",
      "label": "WTI原油",
      "symbol": "CL=F",
      "market": "Commodities",
      "format": "commodity",
      "required": false
    },
    {
      "key": "gold",
      "label": "金",
      "symbol": "GC=F",
      "market": "Commodities",
      "format": "commodity",
      "required": false
    }
  ]
}
